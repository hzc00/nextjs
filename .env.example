# Database Connection (Supabase)
# Get these from Supabase Settings -> Database
DATABASE_URL="postgresql://postgres.[YOUR_PROJECT_ID]:[YOUR_PASSWORD]@aws-1-us-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[YOUR_PROJECT_ID]:[YOUR_PASSWORD]@aws-1-us-west-1.pooler.supabase.com:5432/postgres"

# Auth.js (NextAuth)
# Generate one using: npx auth secret
AUTH_SECRET="your_auth_secret_here"

# Google AI SDK (Gemini)
# Get your API key from: https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY="your_google_api_key_here"

# (Optional) Local Development Database
# DATABASE_URL="postgresql://postgres:admin@localhost:5432/next-app?schema=public"
